{
  "name": "tyreterra",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "api:dev": "npm run start:dev --prefix apps/api",
    "api:build": "npm run build --prefix apps/api",
    "web:dev": "npm run dev --prefix apps/web",
    "web:build": "npm run build --prefix apps/web",
    "test": "npm run test --prefix apps/api",
    "test:cov": "npm run test:cov --prefix apps/api"
  },
  "dependencies": {
    "@nestjs/schedule": "^6.1.3",
    "cron": "^4.4.0"
  }
}
